# Kalshi API (required for trading)
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=path/to/private_key.pem
# Or paste PEM directly (optional; path takes precedence):
# KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Base URL: demo or production
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Optional: bot config overrides (defaults in config.py)
# ENTRY_MIN_PRICE_CENTS=95      # buy YES/NO when that side's bid >= this; order at that side's ask (default 95)
# MAX_SPREAD_CENTS=1            # only buy when that side's bid-ask spread <= this (default 1)
# STOP_LOSS_CENTS=70            # sell YES when YES bid <= 70, sell NO when NO bid <= 70
# MAX_PCT_PER_MARKET=10
# MAX_OPEN_POSITIONS=10
# STOP_LOSS_POLL_SECONDS=30
# DRY_RUN=false
# DISCOVERY_CATEGORIES_FILE=discovery_categories.txt  # one category slug per line (e.g. mens-college-basketball-mens-game)
